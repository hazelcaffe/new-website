---
import About, { frontmatter } from "../content/about.md";
import ButtonGrid from "../components/ButtonGrid.astro";
import Header from "../components/Header.astro";
import LastFmCard from "../components/LastFmCard.astro";
import ProfileCard from "../components/ProfileCard.astro";
import SocialLinks from "../components/SocialLinks.astro";
import VisitorCounter from "../components/VisitorCounter.astro";
import Webring from "../components/Webring.astro";
import Layout from "../layouts/Layout.astro";

const about = frontmatter as {
    eyebrow: string;
    title: string;
};
---

<Layout>
    <div class="page-shell">
        <Header />
        <aside class="service-banner pixel-border">
            If you would like a qwq.sh email (e.g. alice@qwq.sh), shortened qwq.sh URL (e.g. qwq.sh/foo), or your 88x31 button added, please
            <a href="mailto:hazel@qwq.sh">email me!!</a>
        </aside>

        <main id="home" class="desktop-grid">
            <aside class="left-column">
                <ProfileCard />
                <VisitorCounter />
                <section class="window" id="collections">
                    <div class="window-body">
                        <div class="button-grid" aria-live="polite">
                            <ButtonGrid />
                        </div>
                    </div>
                </section>
            </aside>

            <section class="center-column">
                <article class="window welcome-window">
                    <div class="window-body">
                        <div class="welcome-heading">
                            <div>
                                <p class="eyebrow">{about.eyebrow}</p>
                                <h2>{about.title}</h2>
                            </div>
                            <div class="cat-icon" aria-hidden="true">🐈</div>
                        </div>
                        <div class="divider"></div>
                        <div class="about-content">
                            <About />
                        </div>
                    </div>
                </article>
            </section>

            <aside class="right-column">
                <LastFmCard />
                <SocialLinks />
                <Webring />
            </aside>
        </main>
    </div>
</Layout>
