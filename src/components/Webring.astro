---
import webring from "../config/webring.json";

const previous = webring.links
    .filter((link) => link.order < 0)
    .sort((left, right) => right.order - left.order)[0];
const next = webring.links
    .filter((link) => link.order > 0)
    .sort((left, right) => left.order - right.order)[0];

const navigation = [
    previous && { ...previous, label: "previous", direction: "previous" },
    next && { ...next, label: "next", direction: "next" }
].filter((link) => link !== undefined);

const sites = [...webring.links]
    .sort((left, right) => left.order - right.order)
    .map((link) => ({
        ...link,
        label: new URL(link.href).hostname.replace(/^www\./, "")
    }));
---

<section class="window webring" aria-labelledby="webring-title">
    <div class="window-body">
        <h2 id="webring-title">{webring.name}</h2>
        <p>{webring.description}</p>
        <nav aria-label={`${webring.name} navigation`}>
            {
                navigation.map((link) => (
                    <a
                        href={link.href}
                        target="_blank"
                        rel="noreferrer"
                        data-direction={link.direction}
                    >
                        {link.direction === "previous" && <span aria-hidden="true">&larr;</span>}
                        {link.label}
                        {link.direction === "next" && <span aria-hidden="true">&rarr;</span>}
                    </a>
                ))
            }
        </nav>
        <ul class="webring-sites" aria-label={`${webring.name} sites`}>
            {
                sites.map((site) => (
                    <li class:list={{ current: site.order === 0 }}>
                        {site.order === 0 ? (
                            <span>{site.label}</span>
                        ) : (
                            <a href={site.href} target="_blank" rel="noreferrer">
                                {site.label}
                            </a>
                        )}
                    </li>
                ))
            }
        </ul>
    </div>
</section>
