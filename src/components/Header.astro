---
import site from "../config/site.json";
---

<header class="site-header pixel-border">
    <div class="header-copy">
        <p class="eyebrow">{site.header.url}</p>
        <h1>{site.header.name} <span>{site.header.accent}</span></h1>
        <p class="subtitle">{site.header.subtitle}</p>
    </div>
    <div class="header-doodles" aria-hidden="true">
        <span class="sparkle s1">✦</span>
        <span class="sparkle s2">✧</span>
        <span class="sparkle s3">✦</span>
    </div>
</header>
