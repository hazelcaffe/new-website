---
import { execFileSync } from "node:child_process";
import site from "../config/site.json";

let commit = process.env.GITHUB_SHA?.slice(0, 7) || "source";
try {
    commit = execFileSync("git", ["rev-parse", "--short=7", "HEAD"], {
        encoding: "utf8"
    }).trim();
} catch {
    // Deployments without Git metadata retain a useful source link.
}

const commitUrl =
    commit === "source"
        ? "https://github.com/hazelcaffe"
        : `https://github.com/hazelcaffe/new-website/commit/${commit}`;
---

<header class="site-header pixel-border">
    <div class="header-copy">
        <p class="eyebrow">
            {site.header.url}
            <a class="commit-link" href={commitUrl} target="_blank" rel="noreferrer">{commit}</a>
        </p>
        <h1>{site.header.name} <span>{site.header.accent}</span></h1>
        <p class="subtitle">{site.header.subtitle}</p>
    </div>
    <nav class="site-nav" aria-label="Main navigation">
        <a href="/">About</a>
        <a href="/projects">Projects</a>
        <a href="/blog">Blog</a>
        <a href="https://hazelcaffe.atabook.org" target="_blank" rel="noreferrer">Guestbook</a>
        <a href="https://dl.qwq.sh" target="_blank" rel="noreferrer">File Mirror</a>
    </nav>
    <div class="header-doodles" aria-hidden="true">
        <span class="sparkle s1">+</span>
        <span class="sparkle s2">*</span>
        <span class="sparkle s3">+</span>
    </div>
</header>
