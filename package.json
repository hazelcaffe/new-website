        "mime-types": "^3.0.2",
        "unist-util-visit": "^5.0.0"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.6",
        "@biomejs/biome": "^2.3.8",
        "@types/hast": "^3.0.4",
        "@types/mime-types": "^3.0.1",
        "@types/node": "^24.10.1",
        "sharp": "^0.34.5",
        "tsx": "4.21.0",
        "typescript": "^5.9.3"
    }
